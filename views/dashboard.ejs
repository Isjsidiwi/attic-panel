<%- include('partials/head') %>
<style>
  body {
    background-image:
      linear-gradient(rgba(7, 11, 16, .82), rgba(7, 11, 16, .9)),
      url('https://www.cloudsky.biz.id/api/file/9NF1w.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  :root.light-theme body {
    background-image:
      linear-gradient(rgba(244, 247, 246, .78), rgba(244, 247, 246, .9)),
      url('https://www.cloudsky.biz.id/api/file/9NF1w.jpg');
  }
</style>

<div class="layout">
  <%- include('partials/sidebar') %>

  <main class="main">
    <div class="topbar">
      <div>
        <h2 class="page-title">Dashboard</h2>
        <p class="page-sub">Selamat datang, <strong><%= admin.username %></strong></p>
      </div>
      <div class="topbar-right">
        <a href="/admin/keys?filter=active" class="btn-secondary">+ Generate Key</a>
      </div>
    </div>

    <% if (success_msg.length > 0) { %><div class="alert alert-success"><%= success_msg[0] %></div><% } %>
    <% if (error_msg.length > 0)   { %><div class="alert alert-error"><%= error_msg[0] %></div><% } %>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon stat-icon--cyan">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        </div>
        <div class="stat-body">
          <div class="stat-num" data-count="<%= stats.total %>">0</div>
          <div class="stat-label">Total Key</div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon stat-icon--green">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="stat-body">
          <div class="stat-num" data-count="<%= stats.active %>">0</div>
          <div class="stat-label">Key Aktif</div>
        </div>
      </div>
<div class="stat-card">
  <div class="stat-icon stat-icon--warn">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
  </div>
  <div class="stat-body">
    <div class="stat-num" data-count="<%= stats.locked %>">0</div>
    <div class="stat-label">Device Terkunci</div>
  </div>
</div>
</div>

    <!-- Recent Keys -->
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Key Terbaru</h3>
        <a href="/admin/keys" class="link-muted">Lihat semua →</a>
      </div>
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>KEY CODE</th>
              <th>RESOURCE</th>
              <th>STATUS</th>
              <th>DEVICE</th>
              <th>EXPIRED</th>
              <th>LOGIN</th>
            </tr>
          </thead>
          <tbody>
            <% recent.forEach(k => { %>
            <tr>
              <td><code class="key-code"><%= k.key_code %></code></td>
              <td><span class="badge badge-resource"><%= k.resource %></span></td>
              <td>
                <% if (!k.is_active) { %>
                  <span class="badge badge-off">NONAKTIF</span>
                <% } else if (k.expires_at > 0 && k.expires_at <= now) { %>
                  <span class="badge badge-expired">EXPIRED</span>
                <% } else if (k.expires_at == 0) { %>
                  <span class="badge badge-active" style="background: #9b59b6">READY</span>
                <% } else { %>
                  <span class="badge badge-active">AKTIF</span>
                <% } %>
              </td>
              <% const serials = parseSerials(k.device_serials); %>
              <td class="text-muted"><%= serials.length ? serials[0].substring(0,16) + (serials[0].length > 16 ? '…' : '') : '—' %></td>
              <td class="text-muted">
                <% if (k.expires_at == 0) { %>
                  <span style="font-size: 0.75rem; color: #9b59b6; font-weight: bold;">BELUM AKTIF</span>
                <% } else { %>
                  <%= fmtDate(k.expires_at) %>
                  <br>
                  <span class="countdown-timer badge badge-resource" style="font-size: 0.7rem; background: var(--bg-hover); margin-top: 4px; display: inline-block;" data-expires="<%= k.expires_at %>"></span>
                <% } %>
              </td>
              <td><span class="badge badge-count"><%= k.login_count %>×</span></td>
            </tr>
            <% }) %>
            <% if (recent.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted" style="padding:2rem">Belum ada key</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- API Info Grid -->
    <% if (show_api_info) { %>
    <div class="settings-grid">
      <!-- MLBB API -->
      <div class="card card-info">
        <div class="card-header">
          <h3 class="card-title">API: MLBB</h3>
          <span class="dot-green" style="margin-left:auto"></span>
          <span class="text-green" style="font-size:.75rem;margin-left:.5rem">ONLINE</span>
        </div>
        <div style="padding:1rem 1.25rem">
          <div class="api-line">
            <span class="method-badge">POST</span>
            <code class="api-url">/api/game/MLBB</code>
          </div>
          <p class="text-muted" style="font-size:.8rem;margin-top:.75rem">
            Body: <code>user_key</code>, <code>serial</code>, <code>resource</code>
          </p>
        </div>
      </div>



      <!-- Connect API (Universal) -->
      <div class="card card-info">
        <div class="card-header">
          <h3 class="card-title">API: Blood Strike</h3>
          <span class="dot-green" style="margin-left:auto"></span>
          <span class="text-green" style="font-size:.75rem;margin-left:.5rem">ONLINE</span>
        </div>
        <div style="padding:1rem 1.25rem">
          <div class="api-line">
            <span class="method-badge">POST</span>
            <code class="api-url">/api/connect</code>
          </div>
          <p class="text-muted" style="font-size:.8rem;margin-top:.75rem">
            Body: <code>game</code>, <code>user_key</code>, <code>serial</code>
          </p>
        </div>
      </div>

      <!-- 8 Ball Pool API -->
      <div class="card card-info">
        <div class="card-header">
          <h3 class="card-title">API: 8 Ball Pool</h3>
          <span class="dot-green" style="margin-left:auto"></span>
          <span class="text-green" style="font-size:.75rem;margin-left:.5rem">ONLINE</span>
        </div>
        <div style="padding:1rem 1.25rem">
          <div class="api-line">
            <span class="method-badge">POST</span>
            <code class="api-url">/api/game/8bp</code>
          </div>
          <p class="text-muted" style="font-size:.8rem;margin-top:.75rem">
            Body: <code>game</code>, <code>user_key</code>, <code>serial</code>
          </p>
          <p class="text-muted" style="font-size:.8rem;margin-top:.35rem">
            Contoh: <code>game=8BP</code>
          </p>
        </div>
      </div>

      <!-- CODM API -->
      <div class="card card-info">
        <div class="card-header">
          <h3 class="card-title">API: Call Of Duty</h3>
          <span class="dot-green" style="margin-left:auto"></span>
          <span class="text-green" style="font-size:.75rem;margin-left:.5rem">ONLINE</span>
        </div>
        <div style="padding:1rem 1.25rem">
          <div class="api-line">
            <span class="method-badge">POST</span>
            <code class="api-url">/api/codm</code>
          </div>
          <p class="text-muted" style="font-size:.8rem;margin-top:.75rem">
            Body: <code>game</code>, <code>user_key</code>, <code>serial</code>
          </p>
          <p class="text-muted" style="font-size:.8rem;margin-top:.35rem">
            Contoh: <code>game=ASHESZ</code>
          </p>
        </div>
      </div>
    </div>
    <% } %>

  </main>
</div>

<script src="/js/main.js"></script>
<script>
  function updateCountdowns() {
    const now = Math.floor(Date.now() / 1000);
    document.querySelectorAll('.countdown-timer').forEach(el => {
      const expiresAt = parseInt(el.dataset.expires, 10);
      if (!expiresAt) {
        el.style.display = 'none';
        return;
      }
      const diff = expiresAt - now;
      if (diff <= 0) {
        el.textContent = 'Expired';
        el.style.color = '#ef4444';
      } else {
        const d = Math.floor(diff / 86400);
        const h = Math.floor((diff % 86400) / 3600);
        const m = Math.floor((diff % 3600) / 60);
        const s = diff % 60;
        
        let parts = [];
        if (d > 0) parts.push(d + 'd');
        if (h > 0 || d > 0) parts.push(h + 'h');
        if (m > 0 || h > 0 || d > 0) parts.push(m + 'm');
        parts.push(s + 's');
        
        el.textContent = parts.join(' ');
        el.style.color = '#10b981';
      }
    });
  }
  setInterval(updateCountdowns, 1000);
  updateCountdowns();
</script>
</body>
</html>
