<%- include('partials/head') %>

<div class="layout">
  <%- include('partials/sidebar') %>

  <main class="main">
    <div class="topbar">
      <div>
        <h2 class="page-title">Manage Files</h2>
        <p class="page-sub">Upload dan kelola file - Storage: <strong><%= storageMode %></strong></p>
      </div>
      <div class="topbar-right">
        <button class="btn-primary" data-open-modal="modal-upload">+ Upload File</button>
      </div>
    </div>

    <% if (success_msg && success_msg.length > 0) { %><div class="alert alert-success"><%= success_msg[0] %></div><% } %>
    <% if (error_msg && error_msg.length > 0)   { %><div class="alert alert-error"><%= error_msg[0] %></div><% } %>

    <div class="card">
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>NAMA FILE</th>
              <th>UKURAN</th>
              <th>TANGGAL UPLOAD</th>
              <th>URL</th>
              <th>RENAME</th>
              <th>AKSI</th>
            </tr>
          </thead>
          <tbody>
            <% files.forEach(file => { %>
            <tr>
              <td><%= file.name %></td>
              <td><%= file.size %></td>
              <td class="text-muted"><%= file.date ? new Date(file.date).toLocaleString('id-ID') : '-' %></td>
              <td>
                <a href="<%= file.url %>" target="_blank" rel="noopener noreferrer" class="text-muted" style="text-decoration:underline;">Buka/Download</a>
              </td>
              <td>
                <form action="/admin/files/rename" method="POST" class="file-inline-form">
                  <input type="hidden" name="path" value="<%= file.path %>">
                  <input type="text" name="new_name" value="<%= file.name %>" class="field-input file-rename-input" required>
                  <button type="submit" class="btn-secondary btn-sm">Rename</button>
                </form>
              </td>
              <td>
                <form action="/admin/files/delete" method="POST" style="display:inline;" onsubmit="return confirm('Yakin ingin menghapus file ini?');">
                  <input type="hidden" name="path" value="<%= file.path %>">
                  <input type="hidden" name="sha" value="<%= file.sha || '' %>">
                  <button type="submit" class="btn-icon btn-del" title="Hapus">x</button>
                </form>
              </td>
            </tr>
            <% }) %>
            <% if (files.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center text-muted" style="padding:3rem">Belum ada file yang diupload.</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<div class="modal-overlay" id="modal-upload">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Upload File Baru</h3>
      <button class="modal-close">x</button>
    </div>
    <form action="/admin/files/upload" method="POST" enctype="multipart/form-data" class="modal-form">
      <div class="field">
        <label class="field-label">PILIH FILE</label>
        <input type="file" name="file" class="field-input" required style="padding: 1rem 0;">
        <p class="field-hint">Jika GitHub env sudah diatur, file akan disimpan ke <code><%= githubConfig.owner || 'GITHUB_OWNER' %>/<%= githubConfig.repo || 'GITHUB_REPO' %>:<%= githubConfig.basePath %></code>.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost modal-cancel">Batal</button>
        <button type="submit" class="btn-primary">Upload</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
