<%- include('partials/head') %>

<!-- Inject Tailwind CSS specifically for the redesigned login page -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          primary: '#00e5ff',
          secondary: '#a855f7',
          dark: '#070b10',
          darker: '#0c1118',
        },
        fontFamily: {
          sans: ['Poppins', 'sans-serif'],
          mono: ['IBM Plex Mono', 'monospace'],
        }
      }
    }
  }
</script>

<style>
  body {
    background-image: 
      radial-gradient(circle at top right, rgba(168, 85, 247, 0.15), transparent 40%),
      radial-gradient(circle at bottom left, rgba(0, 229, 255, 0.15), transparent 40%),
      url('/img/mobile-bg.png'); /* Base background */
    background-color: #070b10;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    color: #e2e8f0;
    font-family: 'Poppins', sans-serif;
  }
  
  .glass-card {
    background: rgba(12, 17, 24, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }
  
  .input-glow:focus {
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.2);
    border-color: #00e5ff;
  }

  /* Basic Light Theme Overrides */
  :root.light-theme body {
    background: #f4f7f6;
    color: #1a202c;
  }
  :root.light-theme .glass-card {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.1);
  }
  :root.light-theme .dark-text-white {
    color: #1a202c !important;
  }
  :root.light-theme .dark-text-gray {
    color: #4a5568 !important;
  }
  :root.light-theme .dark-input {
    background-color: #ffffff !important;
    border-color: #cbd5e1 !important;
    color: #1a202c !important;
  }
</style>

<div class="min-h-screen flex items-center justify-center p-4">
  <div class="glass-card w-full max-w-md rounded-2xl p-8 relative overflow-hidden transition-all duration-300">
    <!-- Decorative top accent -->
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary via-secondary to-primary"></div>
    
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary/10 mb-4 shadow-[0_0_20px_rgba(0,229,255,0.2)]">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
      </div>
      <h1 class="text-3xl font-bold dark-text-white mb-2 tracking-wide">
        <%= panel_name %>
      </h1>
      <p class="text-sm text-gray-400 dark-text-gray">Authenticate to access the panel</p>
    </div>

    <% if (error_msg && error_msg.length > 0) { %>
      <div class="bg-red-500/10 border border-red-500/50 text-red-400 text-sm p-3 rounded-lg mb-6 flex flex-col gap-2">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span><%= error_msg[0] %></span>
        </div>
        <% if (show_reseller) { %>
          <a href="https://t.me/Joyzzter88888" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-white transition-colors text-xs font-medium self-end">Daftar Reseller &rarr;</a>
        <% } %>
      </div>
    <% } %>

    <form action="/login" method="POST" class="space-y-5" autocomplete="off">
      <div>
        <label class="block text-xs font-semibold text-gray-400 dark-text-gray mb-1.5 tracking-wider">USERNAME</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </div>
          <input type="text" name="username" class="dark-input w-full bg-darker/50 border border-gray-700/50 rounded-xl pl-11 pr-4 py-3 dark-text-white placeholder-gray-600 focus:outline-none input-glow transition-all" placeholder="Enter username" required autofocus spellcheck="false">
        </div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-400 dark-text-gray mb-1.5 tracking-wider">PASSWORD</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
          </div>
          <input type="password" name="password" class="dark-input w-full bg-darker/50 border border-gray-700/50 rounded-xl pl-11 pr-4 py-3 dark-text-white placeholder-gray-600 focus:outline-none input-glow transition-all" placeholder="••••••••" required>
        </div>
      </div>

      <div class="pt-4 flex flex-col gap-3">
        <button type="submit" class="w-full bg-gradient-to-r from-primary to-blue-500 hover:from-blue-400 hover:to-primary text-darker font-bold py-3 rounded-xl shadow-[0_0_15px_rgba(0,229,255,0.4)] hover:shadow-[0_0_25px_rgba(0,229,255,0.6)] transition-all duration-300 tracking-wide text-sm">
          AUTHENTICATE
        </button>
        <div class="grid grid-cols-2 gap-3 mt-1">
          <a href="/store" class="flex items-center justify-center bg-secondary/20 hover:bg-secondary/30 border border-secondary/30 text-secondary hover:text-white py-2.5 rounded-xl transition-all text-sm font-medium">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            Store
          </a>
          <button type="button" onclick="toggleTheme && toggleTheme()" class="flex items-center justify-center bg-gray-800/40 hover:bg-gray-700/60 border border-gray-700/50 text-gray-300 hover:text-white py-2.5 rounded-xl transition-all text-sm font-medium dark-input">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            Theme
          </button>
        </div>
      </div>
    </form>

    <% if (show_api_info) { %>
      <div class="mt-8 pt-6 border-t border-gray-700/50 flex justify-center items-center gap-2 text-xs font-mono text-gray-400 dark-text-gray">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
        </span>
        API: <code class="text-primary bg-primary/10 px-1.5 py-0.5 rounded ml-1">/api/game/MLBB</code> — ONLINE
      </div>
    <% } %>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>