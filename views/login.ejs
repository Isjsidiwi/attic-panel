<%- include('partials/head') %>

<div class="login-page imgui-skin">
  <div class="login-bg">
    <div class="scan-line"></div>
  </div>

  <div class="imgui-container">
    <div class="imgui-left">
      <div class="imgui-artwrap">
        <!-- Placeholder: replace /img/kurumi.png dengan artwork Kurumi yang Anda miliki -->
        <img src="/img/kurumi.png" alt="Kurumi" class="imgui-art" onerror="this.classList.add('missing')">
        <div class="imgui-art-note">Letakkan gambar Kurumi di <code>/public/img/kurumi.png</code></div>
      </div>
    </div>

    <div class="imgui-right">
      <div class="imgui-panel">
        <div class="imgui-titlebar">
          <div class="imgui-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="imgui-title"><%= panel_name %> — Login</div>
        </div>

        <div class="imgui-body">
          <% if (error_msg.length > 0) { %>
            <div class="alert alert-error"><%= error_msg[0] %></div>
          <% } %>

          <form action="/login" method="POST" class="imgui-form" autocomplete="off">
            <div class="imgui-row">
              <label class="imgui-label">USER</label>
              <input type="text" name="username" class="imgui-input" placeholder="admin" required autofocus spellcheck="false">
            </div>

            <div class="imgui-row">
              <label class="imgui-label">PASS</label>
              <input type="password" name="password" class="imgui-input" placeholder="••••••••" required>
            </div>

            <div class="imgui-actions">
              <button type="submit" class="imgui-btn imgui-btn-primary">AUTHENTICATE</button>
              <button type="button" class="imgui-btn imgui-btn-ghost" onclick="toggleTheme()">Theme</button>
            </div>
          </form>

          <div class="login-footer">
            <span class="dot-green"></span>
            API: <code>/api/game/MLBB</code> — ONLINE
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
