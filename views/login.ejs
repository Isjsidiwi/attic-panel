<%- include('partials/head') %>

<div class="login-page imgui-skin">
  <div class="login-bg">
    <div class="scan-line"></div>
  </div>

  <!-- Asset installer / loader overlay -->
  <div id="asset-loader" class="asset-loader" style="display:none">
    <div class="loader-card">
      <div class="spinner" aria-hidden="true"></div>
      <div class="loader-title">Installing assets...</div>
      <div class="loader-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100">
        <div id="loader-fill" class="loader-bar-fill" style="width:0%"></div>
      </div>
      <div id="loader-sub" class="loader-sub">Preparing...</div>
    </div>
  </div>

  <!-- Region/time popup (top-right) -->
  <div id="time-popup" class="time-popup" style="display:none" aria-live="polite">
    <div class="time-card">
      <div class="time-meta">
        <div id="time-region" class="time-region">Region</div>
      </div>
      <div id="time-value" class="time-value">00:00:00</div>
      <button id="time-close" class="time-close" aria-label="Close">✕</button>
    </div>
  </div>

  <div class="imgui-container">
    <div class="imgui-left">
        <div class="imgui-artwrap">
          <div class="imgui-artbox">
            <img src="/img/kurumi.png" alt="Kurumi" class="imgui-art"
              onerror="this.style.display='none'; this.parentNode.querySelector('.imgui-art-fallback').style.display='flex'">
            <div class="imgui-art-fallback" style="display:none;flex-direction:column;align-items:center;gap:.75rem;padding:1rem;">
              <!-- Generic placeholder SVG (non-copyright) -->
              <svg width="220" height="220" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="placeholder">
                <defs>
                  <linearGradient id="g" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#00e5ff" stop-opacity="0.12"/>
                    <stop offset="100%" stop-color="#a855f7" stop-opacity="0.12"/>
                  </linearGradient>
                </defs>
                <rect width="100%" height="100%" rx="10" fill="url(#g)"/>
                <g transform="translate(20,20)" fill="none" stroke="#d4e2f4" stroke-opacity="0.6">
                  <circle cx="90" cy="60" r="36" stroke-width="2.4" fill="#0c1118" />
                  <path d="M10 170 C 30 130, 150 130, 170 170" stroke-width="3" stroke-linecap="round"/>
                  <circle cx="68" cy="54" r="4" fill="#d4e2f4" stroke="none"/>
                  <circle cx="112" cy="54" r="4" fill="#d4e2f4" stroke="none"/>
                </g>
              </svg>
              <div class="imgui-art-note">Gambar tidak ditemukan. Letakkan gambar Kurumi di <code>/public/img/kurumi.png</code></div>
            </div>
          </div>
        </div>
    </div>

    <div class="imgui-right">
      <div class="imgui-panel">
        <div class="imgui-titlebar">
          <div class="imgui-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="imgui-title"><%= panel_name %> — Login</div>
        </div>

        <div class="imgui-body">
          <% if (error_msg.length > 0) { %>
            <div class="alert alert-error"><%= error_msg[0] %></div>
            <% if (show_reseller) { %>
              <div style="margin-top:.6rem">
                <a href="https://t.me/Joyzzter88888" target="_blank" rel="noopener noreferrer" class="btn-secondary">Daftar Reseller</a>
              </div>
            <% } %>
          <% } %>

          <form action="/login" method="POST" class="imgui-form" autocomplete="off">
            <div class="imgui-row">
              <label class="imgui-label">USER</label>
              <input type="text" name="username" class="imgui-input" placeholder="admin" required autofocus spellcheck="false">
            </div>

            <div class="imgui-row">
              <label class="imgui-label">PASS</label>
              <input type="password" name="password" class="imgui-input" placeholder="••••••••" required>
            </div>

            <div class="imgui-actions" style="margin-top: 1rem; flex-wrap: wrap; gap: 0.5rem;">
              <button type="submit" class="imgui-btn imgui-btn-primary" style="flex: 1 1 100%">AUTHENTICATE</button>
              <a href="/store" class="imgui-btn" style="flex: 1; text-align: center; text-decoration: none; background: #a855f7; color: white;">Buy Key</a>
              <button type="button" class="imgui-btn imgui-btn-ghost" onclick="toggleTheme()" style="flex: 1">Theme</button>
            </div>
          </form>

          <% if (show_api_info) { %>
            <div class="login-footer">
              <span class="dot-green"></span>
              API: <code>/api/game/MLBB</code> — ONLINE
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
