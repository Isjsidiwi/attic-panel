<%- include('partials/head') %>

<div class="login-page">
  <!-- Animated grid bg -->
  <div class="login-bg">
    <div class="scan-line"></div>
  </div>

  <div class="login-wrap">
    <div class="login-card">
      <div class="login-brand">
        <div class="login-hex">⬡</div>
        <h1 class="login-title"><%= panel_name %></h1>
        <p class="login-sub">RESTRICTED ACCESS — AUTHORIZED ONLY</p>
      </div>

      <% if (error_msg.length > 0) { %>
        <div class="alert alert-error"><%= error_msg[0] %></div>
      <% } %>

      <form action="/login" method="POST" class="login-form" autocomplete="off">
        <div class="field">
          <label class="field-label">USERNAME</label>
          <input
            type="text"
            name="username"
            class="field-input"
            placeholder="admin"
            required
            autofocus
            spellcheck="false"
          >
        </div>

        <div class="field">
          <label class="field-label">PASSWORD</label>
          <input
            type="password"
            name="password"
            class="field-input"
            placeholder="••••••••"
            required
          >
        </div>

        <button type="submit" class="btn-primary btn-full">
          <span>AUTHENTICATE</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </form>

      <div class="login-footer">
        <span class="dot-green"></span>
        API: <code>/api/game/MLBB</code> — ONLINE
      </div>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
</body>
</html>
