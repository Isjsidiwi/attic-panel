<%- include('partials/head') %>
<% const isOwner = admin && admin.role === 'owner'; %>

<div class="layout">
  <%- include('partials/sidebar') %>

  <main class="main">
    <div class="topbar">
      <div>
        <h2 class="page-title">Manage Keys</h2>
        <p class="page-sub">
          Total <strong><%= total %></strong> key <%= isOwner ? 'terdaftar' : 'milik kamu' %>
          <% if (!isOwner) { %> - Credit: <strong><%= admin.credit %></strong><% } %>
        </p>
      </div>
      <div class="topbar-right">
        <button class="btn-primary" data-open-modal="modal-generate">+ Generate Key</button>
        <% if (isOwner) { %>
          <a href="/admin/keys/export" class="btn-secondary">Export</a>
        <% } %>
      </div>
    </div>

    <% if (success_msg.length > 0) { %><div class="alert alert-success"><%= success_msg[0] %></div><% } %>
    <% if (error_msg.length > 0)   { %><div class="alert alert-error"><%= error_msg[0] %></div><% } %>

    <!-- Filter bar -->
    <div class="filter-bar">
      <form method="GET" action="/admin/keys" class="search-form">
        <input type="text" name="search" class="field-input search-input" placeholder="Cari key, serial, notes…" value="<%= search %>">
        <input type="hidden" name="filter" value="<%= filter %>">
        <button type="submit" class="btn-secondary">Cari</button>
      </form>

      <div class="filter-tabs">
        <a href="/admin/keys?filter=all&search=<%= search %>"      class="filter-tab <%= filter==='all'      ? 'active' : '' %>">Semua</a>
        <a href="/admin/keys?filter=active&search=<%= search %>"   class="filter-tab <%= filter==='active'   ? 'active' : '' %>">Aktif</a>
        <a href="/admin/keys?filter=expired&search=<%= search %>"  class="filter-tab <%= filter==='expired'  ? 'active' : '' %>">Expired</a>
        <a href="/admin/keys?filter=locked&search=<%= search %>"   class="filter-tab <%= filter==='locked'   ? 'active' : '' %>">Terkunci</a>
        <a href="/admin/keys?filter=inactive&search=<%= search %>" class="filter-tab <%= filter==='inactive' ? 'active' : '' %>">Nonaktif</a>
      </div>
    </div>

    <!-- Hidden bulk form (terpisah dari tabel) -->
    <form id="bulk-form" action="/admin/keys/bulk-delete" method="POST" style="display:none">
      <input type="hidden" name="ids" id="bulk-ids-input">
    </form>

    <!-- Bulk action bar -->
    <div class="bulk-bar" id="bulk-bar" style="display:none">
      <span id="bulk-count">0 dipilih</span>
      <button type="button" class="btn-danger btn-sm" data-bulk-action-url="/admin/keys/bulk-delete" data-bulk-action-confirm="Hapus semua yang dipilih?">Hapus</button>
      <% if (admin.role !== 'reseller') { %>
        <button type="button" class="btn-secondary btn-sm" data-bulk-action-url="/admin/keys/bulk-deactivate">Nonaktifkan</button>
      <% } %>
      <button type="button" class="btn-ghost btn-sm" data-clear-selection>Batal</button>
    </div>

    <div class="card">
      <div class="table-wrap">
        <table class="table" id="keys-table">
            <thead>
              <tr>
                <th><input type="checkbox" id="select-all"></th>
                <th>KEY CODE</th>
                <% if (isOwner) { %><th>RESELLER</th><% } %>
                <th>RESOURCE</th>
                <th>STATUS</th>
                <th>DEVICE (TERPAKAI/MAX)</th>
                <th>DIBUAT</th>
                <th>EXPIRED</th>
                <th>HARGA</th>
                <th>LOGIN</th>
                <th>AKSI</th>
              </tr>
            </thead>
            <tbody>
              <% keys.forEach(k => { %>
              <tr>
                <td><input type="checkbox" name="ids" value="<%= k.id %>" class="row-check" onchange="updateBulk()"></td>
                <td>
                  <code class="key-code key-copy" title="Klik untuk copy"><%= k.key_code %></code>
                </td>
                <% if (isOwner) { %>
                  <td><span class="badge badge-count"><%= k.created_by_username || 'owner' %></span></td>
                <% } %>
                <td><span class="badge badge-resource"><%= k.resource %></span></td>
                <td>
                  <% if (!k.is_active) { %>
                    <span class="badge badge-off">NONAKTIF</span>
                  <% } else if (k.expires_at <= now) { %>
                    <span class="badge badge-expired">EXPIRED</span>
                  <% } else { %>
                    <span class="badge badge-active">AKTIF</span>
                  <% } %>
                </td>
                <td class="serial-cell">
                  <% const serials_k = parseSerials(k.device_serials); %>
                  <div class="device-slot-wrap">
                    <span class="device-slot-badge <%= serials_k.length >= k.max_devices ? 'slot-full' : serials_k.length > 0 ? 'slot-partial' : 'slot-empty' %>">
                      <%= serials_k.length %>/<%= k.max_devices %>
                    </span>
                    <% if (serials_k.length > 0) { %>
                      <span class="device-serial-list" title="<%= serials_k.join('\n') %>">
                        <%= serials_k[0].substring(0,14) %><%= serials_k[0].length > 14 ? '…' : '' %><% if (serials_k.length > 1) { %> <span class="text-muted">+<%= serials_k.length - 1 %></span><% } %>
                      </span>
                    <% } else { %>
                      <span class="text-muted" style="font-size:.72rem">Belum ada</span>
                    <% } %>
                  </div>
                </td>
                <td class="text-muted"><%= fmtDate(k.created_at) %></td>
                <td class="<%= k.expires_at <= now ? 'text-danger' : 'text-muted' %>"><%= fmtDate(k.expires_at) %></td>
                <td><span class="badge badge-count"><%= k.price_paid || 0 %></span></td>
                <td><span class="badge badge-count"><%= k.login_count %>×</span></td>
                <td>
                  <div class="action-btns">
                    <% if (admin.role !== 'reseller') { %>
                      <button class="btn-icon btn-edit" data-key-id="<%= k.id %>" title="Edit">✎</button>
                    <% } %>
                    <button class="btn-icon btn-del" data-delete-id="<%= k.id %>" title="Hapus">✕</button>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% if (keys.length === 0) { %>
              <tr>
                <td colspan="<%= isOwner ? 11 : 10 %>" class="text-center text-muted" style="padding:3rem">
                  Tidak ada key ditemukan
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% for (let p = 1; p <= totalPages; p++) { %>
        <a
          href="/admin/keys?page=<%= p %>&filter=<%= filter %>&search=<%= search %>"
          class="page-btn <%= p === currentPage ? 'active' : '' %>"
        ><%= p %></a>
      <% } %>
    </div>
    <% } %>

  </main>
</div>

<!-- ═══════════════════ MODAL: GENERATE ═══════════════════ -->
      <div class="modal-overlay" id="modal-generate">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Generate Key</h3>
            <button class="modal-close">✕</button>
    </div>
    <form action="/admin/keys/generate" method="POST" class="modal-form" data-generate-form>
      <div class="field">
        <label class="field-label">GAME</label>
        <select name="game" class="field-input" required>
          <% gameOptions.forEach(g => { %>
            <option value="<%= g.value %>" <%= g.value === 'CODM' ? 'selected' : '' %>><%= g.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label class="field-label">RESOURCE</label>
        <input type="text" name="resource" class="field-input" value="vip" placeholder="vip / premium / dll" required>
      </div>
      <div class="field-row">
        <div class="field" style="flex:1">
          <label class="field-label">DURASI</label>
          <input type="number" name="duration" class="field-input" value="30" min="1" <%= isOwner ? '' : 'max="30"' %> required>
        </div>
        <% if (isOwner) { %>
        <div class="field" style="flex:1">
          <label class="field-label">UNIT</label>
          <select name="duration_unit" class="field-input">
            <option value="hours">Jam</option>
            <option value="days" selected>Hari</option>
            <option value="months">Bulan</option>
          </select>
        </div>
        <% } else { %>
          <input type="hidden" name="duration_unit" value="days">
          <div class="field" style="flex:1">
            <label class="field-label">UNIT</label>
            <input type="text" class="field-input" value="Hari" readonly>
          </div>
        <% } %>
      </div>
      <div class="field-row">
        <div class="field" style="flex:1">
          <label class="field-label">JUMLAH KEY (bulk)</label>
          <input type="number" name="bulk" class="field-input" value="1" min="1" max="100">
        </div>
        <div class="field" style="flex:1">
          <label class="field-label">MAX DEVICE / KEY</label>
          <input type="number" name="max_devices" class="field-input" value="1" min="1" max="500" title="Berapa device yang bisa login pakai 1 key">
        </div>
      </div>
      <div class="field">
        <label class="field-label">NOTES (opsional)</label>
        <input type="text" name="notes" class="field-input" placeholder="e.g. untuk user A">
      </div>
      <% if (!isOwner) { %>
        <div class="credit-preview" id="credit-preview" data-balance="<%= admin.credit %>">
          Harga akan dihitung dari credit kamu.
        </div>
      <% } %>
      <div class="modal-footer">
        <button type="button" class="btn-ghost modal-cancel">Batal</button>
        <button type="submit" class="btn-primary">Generate</button>
      </div>
    </form>
  </div>
</div>

<!-- ═══════════════════ MODAL: EDIT ═══════════════════ -->
<div class="modal-overlay" id="modal-edit">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Edit Key</h3>
      <button class="modal-close">✕</button>
    </div>
    <form id="edit-form" method="POST" class="modal-form">
      <div class="field">
        <label class="field-label">KEY CODE</label>
        <input type="text" id="edit-key-code" class="field-input" readonly>
      </div>
      <div class="field">
        <label class="field-label">RESOURCE</label>
        <input type="text" name="resource" id="edit-resource" class="field-input" required>
      </div>
      <div class="field">
        <label class="field-label">EXPIRED DATE & TIME</label>
        <input type="datetime-local" name="expires_at_input" id="edit-expires" class="field-input" required>
      </div>
      <div class="field">
        <label class="field-label">STATUS</label>
        <select name="is_active" id="edit-active" class="field-input">
          <option value="1">Aktif</option>
          <option value="0">Nonaktif</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label">MAX DEVICE / KEY</label>
        <input type="number" name="max_devices" id="edit-max-devices" class="field-input" min="1" max="500">
        <p class="field-hint">Ubah kapasitas device. Jika dikecilkan di bawah jumlah serial terdaftar, device lama tetap tersimpan tapi slot tidak bisa bertambah.</p>
      </div>
      <div class="field">
        <label class="field-label">DEVICE TERDAFTAR</label>
        <div id="edit-serials-list" class="serials-box"></div>
      </div>
      <div class="field-check">
        <label class="check-label">
          <input type="checkbox" name="reset_devices" value="1" id="edit-reset-devices">
          <span>Reset semua device (hapus semua serial terdaftar)</span>
        </label>
      </div>
      <div class="field">
        <label class="field-label">NOTES</label>
        <input type="text" name="notes" id="edit-notes" class="field-input">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-ghost modal-cancel">Batal</button>
        <button type="submit" class="btn-primary">Simpan</button>
      </div>
    </form>
  </div>
</div>

<!-- ═══════════════════ MODAL: DELETE ═══════════════════ -->
<div class="modal-overlay" id="modal-delete">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h3 class="modal-title text-danger">Hapus Key</h3>
      <button class="modal-close">✕</button>
    </div>
    <div style="padding:1.25rem">
      <p class="text-muted">Yakin ingin menghapus key:</p>
      <code id="delete-key-display" class="key-code" style="display:block;margin:.75rem 0"></code>
      <p class="text-muted" style="font-size:.8rem">Tindakan ini tidak bisa dibatalkan.</p>
    </div>
    <form id="delete-form" method="POST" class="modal-footer">
      <button type="button" class="btn-ghost modal-cancel">Batal</button>
      <button type="submit" class="btn-danger">Hapus</button>
    </form>
  </div>
</div>

<div id="toast" class="toast"></div>
<script>
  window.KEY_PRICES = <%- JSON.stringify(priceMatrix || {}) %>;
  window.USER_CREDIT = <%= Number(admin.credit) || 0 %>;
  window.KEYS_MAP = <%- JSON.stringify((keys || []).reduce((m,k)=>{ m[k.id]=k; return m; }, {})) %>;
</script>
<script src="/js/main.js"></script>
</body>
</html>
