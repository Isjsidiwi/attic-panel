<footer class="mt-20 py-10 text-center relative z-10" style="border-top:1px solid var(--border); background: rgba(9, 9, 11, 0.8); backdrop-filter: blur(10px);">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">Payment Support</p>
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-xs font-bold text-white shadow-sm">QRIS</span>
      <span class="px-3 py-1.5 rounded-lg bg-[#00AED6]/10 border border-[#00AED6]/20 text-xs font-bold text-[#00AED6] shadow-sm">GoPay</span>
      <span class="px-3 py-1.5 rounded-lg bg-[#118EEA]/10 border border-[#118EEA]/20 text-xs font-bold text-[#118EEA] shadow-sm">DANA</span>
      <span class="px-3 py-1.5 rounded-lg bg-[#4C3494]/10 border border-[#4C3494]/20 text-xs font-bold text-[#9b7df0] shadow-sm">OVO</span>
      <span class="px-3 py-1.5 rounded-lg bg-[#0066AE]/10 border border-[#0066AE]/20 text-xs font-bold text-[#459ce0] shadow-sm">BCA</span>
      <span class="px-3 py-1.5 rounded-lg bg-[#00529C]/10 border border-[#00529C]/20 text-xs font-bold text-[#4e9de2] shadow-sm">BRI</span>
      <span class="px-3 py-1.5 rounded-lg bg-[#FF6B00]/10 border border-[#FF6B00]/20 text-xs font-bold text-[#ff8f3d] shadow-sm">SeaBank</span>
      <span class="px-3 py-1.5 rounded-lg bg-[#F7A600]/10 border border-[#F7A600]/20 text-xs font-bold text-[#ffc145] shadow-sm">Bank Jago</span>
    </div>
    <p class="mono text-xs" style="color:var(--muted);opacity:.5">&copy; <%= new Date().getFullYear() %> <%= storeName %></p>
  </div>
</footer>
</div><!-- wrap -->
<script>
  window.addEventListener('load', () => {
    const loader = document.getElementById('loader');
    if (loader) {
      loader.classList.add('loading-finished');
      setTimeout(() => loader.remove(), 600);
    }
  });
</script>
</body>
</html>
