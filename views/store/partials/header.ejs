<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %><%= storeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #09090b; /* Very dark zinc */
      --surface: #18181b; /* Dark zinc */
      --surface2: #27272a;
      --border: #3f3f46;
      --accent: #3b82f6; /* Blue 500 */
      --accent-hover: #2563eb;
      --text: #f8fafc;
      --muted: #a1a1aa;
    }
    * { box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; min-height: 100vh; -webkit-font-smoothing: antialiased; 
      background-image: url('https://www.cloudsky.biz.id/api/file/Wallpaper%20Anime%20Frieren%20Gunung%20Musim%20Dingin%20-%204K.png');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      background-repeat: no-repeat;
    }
    
    @media (max-width: 768px) {
      body {
        background-image: url('https://www.cloudsky.biz.id/api/file/9NF1w.jpg');
      }
    }

    .bg-overlay {
      position: fixed;
      inset: 0;
      background: rgba(9, 9, 11, 0.7);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      z-index: 0;
      pointer-events: none;
    }

    .mono { font-family: 'JetBrains Mono', monospace; }
    
    .card { background: rgba(24, 24, 27, 0.85); backdrop-filter: blur(10px); border: 1px solid var(--border); border-radius: 16px; transition: all 0.3s ease; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2); }
    .card:hover { border-color: #52525b; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -2px rgba(0, 0, 0, 0.2); }
    
    .btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; padding: 0.75rem 1.5rem; font-weight: 600; font-size: 0.95rem; transition: all 0.2s ease; cursor: pointer; }
    .btn-primary { background: var(--text); color: var(--bg); border: 1px solid transparent; }
    .btn-primary:hover { background: #e2e8f0; transform: translateY(-1px); }
    .btn-outline { background: transparent; color: var(--text); border: 1px solid var(--border); }
    .btn-outline:hover { background: var(--surface2); border-color: #52525b; }
    
    .badge { font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 9999px; letter-spacing: 0.02em; }
    .badge-green { background: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.2); }
    .badge-red { background: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2); }
    .badge-gray { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }
    
    .field { background: rgba(9, 9, 11, 0.8); border: 1px solid var(--border); color: var(--text); border-radius: 10px; padding: 0.75rem 1rem; font-family: 'Inter', sans-serif; transition: all 0.2s ease; outline: none; width: 100%; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1); }
    .field:focus { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2); }
    
    .mesh { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at top, rgba(59,130,246,0.15) 0%, transparent 50%); pointer-events: none; z-index: 0; }
    .wrap { position: relative; z-index: 1; }
    
    nav { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); background: rgba(9, 9, 11, 0.6) !important; border-bottom: 1px solid rgba(63, 63, 70, 0.5); }

    /* 3D Animated Text */
    .text-3d-animated {
      display: inline-block;
      transform-style: preserve-3d;
      animation: float3d 4s ease-in-out infinite;
      text-shadow: 
        0 1px 0 #cccccc,
        0 2px 0 #c9c9c9,
        0 3px 0 #bbb,
        0 4px 0 #b9b9b9,
        0 5px 0 #aaa,
        0 6px 1px rgba(0,0,0,.1),
        0 0 5px rgba(0,0,0,.1),
        0 1px 3px rgba(0,0,0,.3),
        0 3px 5px rgba(0,0,0,.2),
        0 5px 10px rgba(0,0,0,.25),
        0 10px 10px rgba(0,0,0,.2),
        0 20px 20px rgba(0,0,0,.15);
    }
    
    @keyframes float3d {
      0%, 100% { transform: translateY(0) rotateX(10deg) rotateY(-5deg); }
      50% { transform: translateY(-10px) rotateX(20deg) rotateY(5deg); text-shadow: 0 1px 0 #cccccc, 0 2px 0 #c9c9c9, 0 3px 0 #bbb, 0 4px 0 #b9b9b9, 0 5px 0 #aaa, 0 15px 5px rgba(0,0,0,.1), 0 0 5px rgba(0,0,0,.1), 0 1px 3px rgba(0,0,0,.3), 0 3px 5px rgba(0,0,0,.2), 0 5px 10px rgba(0,0,0,.25), 0 15px 15px rgba(0,0,0,.2), 0 30px 30px rgba(0,0,0,.15); }
    }

    /* Advanced Asset Loading Animation */
    .asset-loader { position: fixed; inset: 0; background: var(--bg); z-index: 99999; display: flex; align-items: center; justify-content: center; flex-direction: column; transition: opacity 0.6s ease, visibility 0.6s ease; }
    .loader-card { background: var(--surface); border: 1px solid var(--border); padding: 2.5rem; border-radius: 20px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); width: 90%; max-width: 400px; text-align: center; }
    .loader-spinner { width: 50px; height: 50px; border: 4px solid rgba(59, 130, 246, 0.1); border-radius: 50%; border-top-color: var(--accent); animation: spin 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite; margin: 0 auto 1.5rem; }
    .loader-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; letter-spacing: -0.025em; color: var(--text); }
    .loader-bar { width: 100%; height: 8px; background: var(--surface2); border-radius: 999px; overflow: hidden; position: relative; }
    .loader-bar-fill { height: 100%; background: linear-gradient(90deg, #3b82f6, #8b5cf6); border-radius: 999px; width: 0%; transition: width 0.1s linear; position: relative; }
    .loader-bar-fill::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); animation: shimmer 1s infinite linear; }
    .loader-sub { margin-top: 1rem; font-size: 0.85rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; }
    
    @keyframes spin { 100% { transform: rotate(360deg); } }
    @keyframes shimmer { 100% { transform: translateX(100%); } }

    /* Floating CS Button */
    .cs-float { position: fixed; bottom: 24px; right: 24px; z-index: 100; transform: translateY(0); transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .cs-float:hover { transform: translateY(-5px); }
    
    .text-3d-animated {
      display: inline-block;
      transform-style: preserve-3d;
      animation: float3d 4s ease-in-out infinite;
      text-shadow: 
        0 1px 0 #cccccc,
        0 2px 0 #c9c9c9,
        0 3px 0 #bbb,
        0 4px 0 #b9b9b9,
        0 5px 0 #aaa,
        0 6px 1px rgba(0,0,0,.1),
        0 0 5px rgba(0,0,0,.1),
        0 1px 3px rgba(0,0,0,.3),
        0 3px 5px rgba(0,0,0,.2),
        0 5px 10px rgba(0,0,0,.25),
        0 10px 10px rgba(0,0,0,.2),
        0 20px 20px rgba(0,0,0,.15);
    }
    
    @keyframes float3d {
      0%, 100% { transform: translateY(0) rotateX(10deg) rotateY(-5deg); }
      50% { transform: translateY(-10px) rotateX(20deg) rotateY(5deg); text-shadow: 0 1px 0 #cccccc, 0 2px 0 #c9c9c9, 0 3px 0 #bbb, 0 4px 0 #b9b9b9, 0 5px 0 #aaa, 0 15px 5px rgba(0,0,0,.1), 0 0 5px rgba(0,0,0,.1), 0 1px 3px rgba(0,0,0,.3), 0 3px 5px rgba(0,0,0,.2), 0 5px 10px rgba(0,0,0,.25), 0 15px 15px rgba(0,0,0,.2), 0 30px 30px rgba(0,0,0,.15); }
    }

    .asset-loader { position: fixed; inset: 0; background: var(--bg); z-index: 99999; display: flex; align-items: center; justify-content: center; flex-direction: column; transition: opacity 0.6s ease, visibility 0.6s ease; }
    .loader-card { background: var(--surface); border: 1px solid var(--border); padding: 2.5rem; border-radius: 20px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); width: 90%; max-width: 400px; text-align: center; }
    .loader-spinner { width: 50px; height: 50px; border: 4px solid rgba(59, 130, 246, 0.1); border-radius: 50%; border-top-color: var(--accent); animation: spin 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite; margin: 0 auto 1.5rem; }
    .loader-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; letter-spacing: -0.025em; color: var(--text); }
    .loader-bar { width: 100%; height: 8px; background: var(--surface2); border-radius: 999px; overflow: hidden; position: relative; }
    .loader-bar-fill { height: 100%; background: linear-gradient(90deg, #3b82f6, #8b5cf6); border-radius: 999px; width: 0%; transition: width 0.1s linear; position: relative; }
    .loader-bar-fill::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); animation: shimmer 1s infinite linear; }
    .loader-sub { margin-top: 1rem; font-size: 0.85rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; }
    
    @keyframes shimmer { 100% { transform: translateX(100%); } }

    </style>
    <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
    </head>
    <body>
    
    <div class="bg-overlay"></div>
    <!-- Asset Loader Overlay -->
    <div id="asset-loader" class="asset-loader">
      <div class="loader-card">
        <div class="loader-spinner"></div>
        <div class="loader-title">Installing Assets...</div>
        <div class="loader-bar">
          <div id="loader-fill" class="loader-bar-fill"></div>
        </div>
        <div id="loader-sub" class="loader-sub">Preparing resources...</div>
      </div>
    </div>

    <!-- Loader Script -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const loader = document.getElementById("asset-loader");
        const fill = document.getElementById("loader-fill");
        const sub = document.getElementById("loader-sub");
        
        let progress = 0;
        const steps = [
          "Loading modules...",
          "Fetching UI components...",
          "Resolving product models...",
          "Optimizing 3D textures...",
          "Connecting to database...",
          "Finalizing..."
        ];
        
        const interval = setInterval(() => {
          progress += Math.random() * 15;
          if (progress > 100) progress = 100;
          
          fill.style.width = `${progress}%`;
          const stepIndex = Math.min(Math.floor(progress / 20), steps.length - 1);
          sub.innerText = steps[stepIndex] + ` (${Math.floor(progress)}%)`;
          
          if (progress >= 100) {
            clearInterval(interval);
            setTimeout(() => {
              loader.style.opacity = '0';
              loader.style.visibility = 'hidden';
            }, 300);
          }
        }, 120);
      });
    </script>


