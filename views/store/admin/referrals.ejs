<% pageTitle = 'Kelola Referral' %>
<%- include('../partials/header') %>

<main class="max-w-6xl mx-auto px-6 py-12">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-white">Kode Referral</h1>
      <p class="text-sm text-zinc-400 mt-1">Buat dan kelola kode diskon untuk pelanggan.</p>
    </div>
    <div class="flex items-center gap-3">
      <a href="/admin/store" class="btn btn-outline text-sm py-2.5 px-5 rounded-xl border-zinc-800 hover:bg-zinc-900 transition-all flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Kembali
      </a>
    </div>
  </div>

  <% if (success) { %>
    <div class="p-4 rounded-xl mb-6 text-sm bg-green-500/10 border border-green-500/20 text-green-400 flex items-center gap-3">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <%= success %>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="p-4 rounded-xl mb-6 text-sm bg-red-500/10 border border-red-500/20 text-red-400 flex items-center gap-3">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <%= error %>
    </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Form Tambah Referral -->
    <div class="lg:col-span-1">
      <div class="card p-6 border-zinc-800">
        <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Buat Kode Baru
        </h2>
        <form method="POST" action="/admin/store/referrals/add" class="flex flex-col gap-4">
          <div class="space-y-1.5">
            <label class="block text-xs font-semibold text-zinc-400 ml-1">KODE REFERRAL</label>
            <input type="text" name="code" class="field bg-zinc-900 border-zinc-800 focus:border-blue-500/50 text-white" placeholder="Contoh: PROMO2026" required style="text-transform: uppercase;">
          </div>
          <div class="space-y-1.5">
            <label class="block text-xs font-semibold text-zinc-400 ml-1">POTONGAN DISKON (Rp)</label>
            <input type="number" name="discount_amount" class="field bg-zinc-900 border-zinc-800 focus:border-blue-500/50 text-white" placeholder="Contoh: 5000" required>
          </div>
          <div class="space-y-1.5">
            <label class="block text-xs font-semibold text-zinc-400 ml-1">KEDALUWARSA (Opsional)</label>
            <input type="datetime-local" name="expired_at" class="field bg-zinc-900 border-zinc-800 focus:border-blue-500/50 text-white">
            <p class="text-[10px] text-zinc-500 ml-1">Kosongkan jika ingin berlaku selamanya (lifetime).</p>
          </div>
          <div class="space-y-1.5">
            <label class="block text-xs font-semibold text-zinc-400 ml-1">BERLAKU UNTUK PRODUK</label>
            <div class="max-h-40 overflow-y-auto bg-zinc-900 border border-zinc-800 rounded-xl p-3">
              <% products.forEach(p => { %>
                <label class="flex items-center gap-2 mb-2 cursor-pointer">
                  <input type="checkbox" name="allowed_products" value="<%= p.id %>" class="accent-blue-500 w-4 h-4 rounded">
                  <span class="text-sm text-zinc-300"><%= p.name %></span>
                </label>
              <% }) %>
              <% if (products.length === 0) { %>
                <p class="text-xs text-zinc-500">Belum ada produk.</p>
              <% } %>
            </div>
            <p class="text-[10px] text-zinc-500 ml-1">Kosongkan/jangan centang untuk semua produk.</p>
          </div>
          <button type="submit" class="btn bg-white text-black hover:bg-zinc-200 text-sm py-3 mt-2 rounded-xl font-bold transition-all shadow-lg">Tambahkan Kode</button>
        </form>
      </div>
    </div>

    <!-- Daftar Referral -->
    <div class="lg:col-span-2">
      <div class="card overflow-hidden border-zinc-800">
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead class="text-xs text-zinc-400 bg-zinc-900/50 border-b border-zinc-800 uppercase font-semibold tracking-wider">
              <tr>
                <th class="px-6 py-4">Kode</th>
                <th class="px-6 py-4">Diskon</th>
                <th class="px-6 py-4">Produk Diizinkan</th>
                <th class="px-6 py-4">Status / Kedaluwarsa</th>
                <th class="px-6 py-4 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-800/50">
              <% referrals.forEach(ref => { %>
                <tr class="hover:bg-zinc-900/20 transition-colors">
                  <td class="px-6 py-4 font-bold text-blue-400 tracking-widest"><%= ref.code %></td>
                  <td class="px-6 py-4 font-bold text-white">Rp <%= Number(ref.discount_amount).toLocaleString('id-ID') %></td>
                  <td class="px-6 py-4 text-zinc-400 text-xs">
                    <% 
                      let allowed = [];
                      try { allowed = JSON.parse(ref.allowed_products || '[]'); } catch(e){}
                      if (allowed.length === 0) {
                        %>Semua<%
                      } else {
                        %><%= allowed.length %> Produk<%
                      }
                    %>
                  </td>
                  <td class="px-6 py-4 text-zinc-400">
                    <% 
                      let isExpired = false;
                      if (ref.expired_at) {
                        const expDate = new Date(ref.expired_at);
                        isExpired = expDate < new Date();
                        %><%= expDate.toLocaleString('id-ID') %><%
                      } else {
                        %>Selamanya<%
                      }
                    %>
                    <% if (isExpired) { %>
                      <span class="ml-2 px-2 py-0.5 rounded text-[10px] font-bold bg-red-500/10 text-red-400 border border-red-500/20">EXPIRED</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <form method="POST" action="/admin/store/referrals/<%= ref.id %>/delete" onsubmit="return confirm('Hapus kode referral ini?')" style="display:inline;">
                      <button type="submit" class="text-red-400 hover:text-red-300 font-medium">Hapus</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
              <% if (referrals.length === 0) { %>
                <tr>
                  <td colspan="4" class="px-6 py-12 text-center text-zinc-500 font-medium bg-zinc-900/10">Belum ada kode referral yang dibuat.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    
  </div>
</main>

<%- include('../partials/footer') %>