<% pageTitle = 'Beranda' %>
<%- include('partials/header') %>

<style>
  /* Base store overrides to match CHEATGAME theme structure but with BLUE colors */
  .cg-bg { background: #0D1117; }
  .cg-card { background: #161B22; border: 1px solid #30363D; border-radius: 12px; }
  .cg-card-hover:hover { border-color: #3b82f6; box-shadow: 0 0 15px rgba(59, 130, 246, 0.15); }
  .cg-text-primary { color: #60a5fa; } /* text-blue-400 */
  .cg-bg-primary { background: #3b82f6; color: #ffffff; } /* bg-blue-500 */
  .cg-btn-primary { background: #3b82f6; color: #ffffff; font-weight: bold; border-radius: 8px; transition: all 0.2s; }
  .cg-btn-primary:hover { background: #2563eb; } /* bg-blue-600 */
  .cg-btn-outline { border: 1px solid #3b82f6; color: #60a5fa; background: transparent; transition: all 0.2s; }
  .cg-btn-outline:hover { background: rgba(59, 130, 246, 0.1); }
  
  /* Scrollbar hiding for horizontal scroll */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<main class="max-w-6xl mx-auto px-4 py-8">

  <!-- ANNOUNCEMENT BAR -->
  <div class="cg-card px-4 py-3 flex flex-col md:flex-row items-center gap-4 mb-6">
    <div class="flex items-center gap-2 cg-text-primary font-bold text-sm whitespace-nowrap">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg>
      INFORMASI PENTING
    </div>
    <div class="hidden md:block w-px h-4 bg-zinc-700"></div>
    <div class="text-xs md:text-sm text-zinc-300 flex-1">
      <span class="cg-text-primary font-bold">Layanan Digital Otomatis 24 Jam</span>
      <span class="mx-2 text-zinc-600">|</span>
      Transaksi instan, pastikan ID/Data tujuan Anda valid sebelum melakukan pembayaran.
    </div>
  </div>

  <!-- STATS BANNER -->
  <div class="cg-card p-6 md:p-8 mb-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
    <div class="flex flex-col items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center cg-text-primary">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      </div>
      <div>
        <div class="text-xl md:text-2xl font-black text-white">10.000+</div>
        <div class="text-xs text-zinc-400 mt-1">Transaksi</div>
      </div>
    </div>
    <div class="flex flex-col items-center gap-3 relative">
      <div class="hidden md:block absolute left-0 top-1/2 -translate-y-1/2 w-px h-12 bg-zinc-800"></div>
      <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center cg-text-primary">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
      </div>
      <div>
        <div class="text-xl md:text-2xl font-black text-white">Auto</div>
        <div class="text-xs text-zinc-400 mt-1">Delivery</div>
      </div>
    </div>
    <div class="flex flex-col items-center gap-3 relative">
      <div class="hidden md:block absolute left-0 top-1/2 -translate-y-1/2 w-px h-12 bg-zinc-800"></div>
      <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center cg-text-primary">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      </div>
      <div>
        <div class="text-xl md:text-2xl font-black text-white">Secure</div>
        <div class="text-xs text-zinc-400 mt-1">Payment</div>
      </div>
    </div>
    <div class="flex flex-col items-center gap-3 relative">
      <div class="hidden md:block absolute left-0 top-1/2 -translate-y-1/2 w-px h-12 bg-zinc-800"></div>
      <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center cg-text-primary">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      </div>
      <div>
        <div class="text-xl md:text-2xl font-black text-white">24/7</div>
        <div class="text-xs text-zinc-400 mt-1">Support</div>
      </div>
    </div>
  </div>

  <!-- FLASH SALE -->
  <div class="cg-card p-6 mb-8 relative overflow-hidden border-blue-500/20" style="background: linear-gradient(145deg, #161B22 0%, #0d1219 100%);">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
      <h2 class="text-2xl font-black cg-text-primary flex items-center gap-2">
        <div class="w-8 h-8 rounded-full bg-blue-500 text-white flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        FLASH SALE
      </h2>
      <div class="border border-blue-500/30 rounded-full px-4 py-1.5 text-sm font-bold flex items-center gap-2 w-fit">
        <span class="cg-text-primary">Berakhir dalam</span>
        <span class="text-white" id="flash-timer">03:42:44</span>
      </div>
    </div>

    <!-- Flash Sale Products Mockup -->
    <div id="flash-scroll" class="flex gap-4 overflow-x-auto no-scrollbar pb-4 snap-x scroll-smooth">
      <% products.slice(0, 3).forEach(p => { %>
      <a href="/store/produk/<%= p.slug %>" class="min-w-[280px] md:min-w-[320px] snap-center bg-[#1a202c] rounded-xl flex border border-zinc-800 relative overflow-hidden group hover:border-blue-500/50 transition-colors">
        <div class="absolute top-2 left-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full z-10 shadow-lg">-10%</div>
        <div class="w-[40%] bg-zinc-900 relative">
           <img src="<%= p.logo_url || 'https://via.placeholder.com/150' %>" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300">
        </div>
        <div class="p-4 flex flex-col justify-center w-[60%]">
          <div class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider mb-1 line-clamp-1"><%= p.category %></div>
          <h3 class="text-white font-black text-[13px] md:text-sm mb-2 leading-tight uppercase line-clamp-2"><%= p.name %></h3>
          <div class="text-blue-400 font-black text-sm md:text-base mb-1">
            Rp <%= Number((p.min_price || 150000) * 0.9).toLocaleString('id-ID') %>
            <span class="text-zinc-500 text-[10px] md:text-xs line-through ml-1">Rp <%= Number(p.min_price || 150000).toLocaleString('id-ID') %></span>
          </div>
          <div class="mt-2 text-[10px] font-bold text-blue-400 bg-blue-500/10 border border-blue-500/20 w-fit px-2.5 py-0.5 rounded-full">Sisa <%= p.stock || 5 %></div>
        </div>
      </a>
      <% }) %>
      <% if (products.length === 0) { %>
        <div class="text-zinc-500 text-sm italic">Belum ada produk Flash Sale saat ini.</div>
      <% } %>
    </div>
    
    <!-- Dots mockup -->
    <div class="flex justify-center gap-1.5 mt-2">
      <div class="w-6 h-1.5 rounded-full bg-blue-500"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-zinc-700"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-zinc-700"></div>
      <div class="w-1.5 h-1.5 rounded-full bg-zinc-700"></div>
    </div>
  </div>

  <!-- SEARCH & CATEGORIES -->
  <form action="/store/" method="GET" class="mb-8">
    <div class="relative flex items-center mb-6">
      <input type="text" name="q" value="<%= q || '' %>" class="w-full bg-[#161B22] border border-zinc-700 rounded-full py-3.5 md:py-4 pl-6 pr-32 text-zinc-200 placeholder-zinc-500 focus:outline-none focus:border-blue-500 transition-colors" placeholder="Cari brand, produk, Android, iOS, PC, Account...">
      <button type="submit" class="absolute right-2 top-2 bottom-2 cg-btn-primary px-5 md:px-8 rounded-full flex items-center gap-2 shadow-lg shadow-blue-500/10">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
        <span class="hidden md:inline">Cari</span>
      </button>
    </div>
    
    <div class="flex flex-wrap gap-2 md:gap-3">
      <a href="/store/" class="px-5 py-2 rounded-full font-bold text-xs md:text-sm flex items-center gap-2 transition-all <%= !selectedCategory || selectedCategory === 'all' ? 'cg-bg-primary shadow-lg shadow-blue-500/10' : 'bg-[#161B22] text-zinc-400 border border-zinc-700 hover:border-blue-500/50 hover:text-blue-400' %>">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
        Semua
      </a>
      <% categories.forEach(c => { %>
        <a href="/store/?cat=<%= encodeURIComponent(c.category) %>" class="px-5 py-2 rounded-full font-bold text-xs md:text-sm flex items-center gap-2 transition-all <%= selectedCategory === c.category ? 'cg-bg-primary shadow-lg shadow-blue-500/10' : 'bg-[#161B22] text-zinc-400 border border-zinc-700 hover:border-blue-500/50 hover:text-blue-400' %>">
          <%= c.category %>
        </a>
      <% }) %>
    </div>
  </form>

  <!-- PRODUCTS GRID ("Pilih Game") -->
  <div class="cg-card p-6 md:p-8 mb-12">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-1.5 h-8 bg-blue-500 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
      <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight">Pilih <span class="cg-text-primary">Game</span></h2>
    </div>

    <% if (products.length === 0) { %>
      <div class="text-center py-20 text-zinc-500 border border-zinc-800 border-dashed rounded-2xl bg-zinc-900/30">
        <div class="text-4xl mb-3 opacity-30">📦</div>
        <p class="font-medium">Belum ada produk untuk kategori ini.</p>
      </div>
    <% } else { %>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-5">
        <% products.forEach(p => { %>
          <a href="/store/produk/<%= p.slug %>" class="block bg-[#12161c] border border-[#2a303c] hover:border-blue-500 hover:shadow-[0_0_20px_rgba(59,130,246,0.15)] rounded-2xl group flex flex-col h-full overflow-hidden transition-all duration-300">
            <div class="relative w-full aspect-square bg-zinc-900 overflow-hidden">
              <% if (p.logo_url) { %>
                <img src="<%= p.logo_url %>" alt="<%= p.name %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-zinc-700 text-4xl font-black group-hover:scale-110 transition-transform duration-500">AP</div>
              <% } %>
              <div class="absolute inset-0 bg-gradient-to-t from-[#12161c] to-transparent opacity-80"></div>
            </div>
            
            <div class="p-4 flex flex-col flex-1 items-center text-center -mt-6 relative z-10">
              <h3 class="font-black text-white text-[13px] md:text-[15px] mb-3 leading-tight uppercase line-clamp-2 drop-shadow-md"><%= p.name %></h3>
              
              <div class="text-[10px] md:text-xs text-blue-400 font-bold mb-4 flex items-center gap-1.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/></svg>
                <%= p.stock > 0 ? p.stock + ' Brand Tersedia' : 'Habis' %>
              </div>
              
              <div class="mt-auto w-full">
                <div class="cg-btn-outline w-full py-2.5 text-xs font-bold text-center rounded-xl flex justify-center items-center gap-2 group-hover:bg-blue-500 group-hover:text-white transition-colors duration-300">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  Lihat Produk
                </div>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- REVIEWS SECTION -->
  <div class="cg-card p-6 md:p-8 mb-12 relative overflow-hidden" style="background: radial-gradient(circle at top left, rgba(59,130,246,0.06) 0%, transparent 60%), #161B22;">
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <div class="w-1.5 h-8 bg-blue-500 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
        <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight">Apa Kata <span class="cg-text-primary">Mereka?</span></h2>
      </div>
      <a href="#" class="cg-btn-outline text-xs px-4 py-2 rounded-full flex items-center gap-2">
        Lihat Semua <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="flex flex-col md:flex-row gap-8">
      <div class="md:w-1/3">
        <div class="inline-flex items-center gap-1.5 border border-blue-500/30 text-blue-400 text-[10px] md:text-xs font-bold px-3 py-1.5 rounded-full mb-4 bg-blue-500/5 uppercase tracking-wider">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
          Review Terverifikasi
        </div>
        <h3 class="text-2xl md:text-3xl font-black text-white leading-tight mb-8">Review asli dari pengguna<br><span class="text-zinc-400">STORE KAMI</span></h3>
        <div class="flex gap-3">
          <div class="border border-zinc-800 bg-[#12161c] rounded-xl p-3 text-center flex-1">
            <div class="text-blue-400 font-black text-xl">5★</div>
            <div class="text-[9px] font-bold text-zinc-500 uppercase mt-1">RATING</div>
          </div>
          <div class="border border-zinc-800 bg-[#12161c] rounded-xl p-3 text-center flex-1">
            <div class="text-blue-400 font-black text-xl">24/7</div>
            <div class="text-[9px] font-bold text-zinc-500 uppercase mt-1">SUPPORT</div>
          </div>
          <div class="border border-zinc-800 bg-[#12161c] rounded-xl p-3 text-center flex-1">
            <div class="text-blue-400 font-black text-xl">Fast</div>
            <div class="text-[9px] font-bold text-zinc-500 uppercase mt-1">DELIVERY</div>
          </div>
        </div>
      </div>

      <div id="review-scroll" class="md:w-2/3 flex gap-4 overflow-x-auto no-scrollbar pb-4 snap-x scroll-smooth">
        <!-- Mock Review 1 -->
        <div class="min-w-[280px] snap-center bg-[#1a202c] border border-zinc-800 rounded-2xl p-6 flex flex-col relative">
          <div class="absolute top-4 right-6 text-zinc-700 opacity-20 text-7xl font-serif">"</div>
          <div class="flex gap-1 text-blue-400 mb-4 z-10 text-sm">
            ★ ★ ★ ★ ★
          </div>
          <p class="text-zinc-300 text-sm font-medium italic mb-6 flex-1 z-10 leading-relaxed">
            "Sangat cepat dan otomatis masuk, mantap layanannya."
          </p>
          <div class="bg-blue-500/5 border border-blue-500/20 text-blue-400 text-[10px] font-bold px-3 py-1.5 rounded-full w-fit mb-6 flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            X3NEXT DFM - KEY 1 DAY
          </div>
          <div class="flex items-center gap-3 mt-auto">
            <div class="w-10 h-10 rounded-xl bg-blue-500 text-white font-black flex items-center justify-center text-lg">W</div>
            <div>
              <div class="font-bold text-white text-sm">wan</div>
              <div class="text-[10px] text-green-400 flex items-center gap-1 font-bold mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> Verified Customer
              </div>
            </div>
          </div>
        </div>

        <!-- Mock Review 2 -->
        <div class="min-w-[280px] snap-center bg-[#1a202c] border border-zinc-800 rounded-2xl p-6 flex flex-col relative">
          <div class="absolute top-4 right-6 text-zinc-700 opacity-20 text-7xl font-serif">"</div>
          <div class="flex gap-1 text-blue-400 mb-4 z-10 text-sm">
            ★ ★ ★ ★ ★
          </div>
          <p class="text-zinc-300 text-sm font-medium italic mb-6 flex-1 z-10 leading-relaxed">
            "Beli tengah malam pun langsung diproses. The best!"
          </p>
          <div class="bg-blue-500/5 border border-blue-500/20 text-blue-400 text-[10px] font-bold px-3 py-1.5 rounded-full w-fit mb-6 flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            PUBGM VVIP - KEY 30 DAY
          </div>
          <div class="flex items-center gap-3 mt-auto">
            <div class="w-10 h-10 rounded-xl bg-blue-500 text-white font-black flex items-center justify-center text-lg">C</div>
            <div>
              <div class="font-bold text-white text-sm">cakir</div>
              <div class="text-[10px] text-green-400 flex items-center gap-1 font-bold mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> Verified Customer
              </div>
            </div>
          </div>
        </div>

        <!-- Mock Review 3 -->
        <div class="min-w-[280px] snap-center bg-[#1a202c] border border-zinc-800 rounded-2xl p-6 flex flex-col relative">
          <div class="absolute top-4 right-6 text-zinc-700 opacity-20 text-7xl font-serif">"</div>
          <div class="flex gap-1 text-blue-400 mb-4 z-10 text-sm">
            ★ ★ ★ ★ ★
          </div>
          <p class="text-zinc-300 text-sm font-medium italic mb-6 flex-1 z-10 leading-relaxed">
            "Admin fast respon dan harga sangat bersahabat."
          </p>
          <div class="bg-blue-500/5 border border-blue-500/20 text-blue-400 text-[10px] font-bold px-3 py-1.5 rounded-full w-fit mb-6 flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            ZOLO - KEY 1 DAY
          </div>
          <div class="flex items-center gap-3 mt-auto">
            <div class="w-10 h-10 rounded-xl bg-blue-500 text-white font-black flex items-center justify-center text-lg">Z</div>
            <div>
              <div class="font-bold text-white text-sm">Zian</div>
              <div class="text-[10px] text-green-400 flex items-center gap-1 font-bold mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> Verified Customer
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- HOW TO ORDER -->
  <div class="cg-card p-6 md:p-8">
    <div class="flex items-center gap-3 mb-8">
      <div class="w-1.5 h-8 bg-blue-500 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
      <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight">Cara Mudah <span class="cg-text-primary">Memesan</span></h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      <div class="bg-[#12161c] border border-zinc-800 rounded-2xl p-6 text-center relative group hover:border-blue-500/30 transition-colors">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-6 h-6 bg-blue-500 text-white font-black text-xs rounded-full flex items-center justify-center ring-4 ring-[#161B22]">1</div>
