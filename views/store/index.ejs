<script>
  // Simple Mock Flash Timer
  setInterval(() => {
    const el = document.getElementById('flash-timer');
    if (!el) return;
    let [h, m, s] = el.innerText.split(':').map(Number);
    if (s > 0) s--;
    else if (m > 0) { s = 59; m--; }
    else if (h > 0) { s = 59; m = 59; h--; }
    el.innerText = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  }, 1000);

  // Auto Scroll for horizontal lists
  function setupAutoScroll(id, intervalTime) {
    const el = document.getElementById(id);
    if (!el) return;
    setInterval(() => {
      const maxScrollLeft = el.scrollWidth - el.clientWidth;
      if (el.scrollLeft >= maxScrollLeft - 10) {
        // Reset ke awal jika mentok
        el.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        // Scroll sejauh ukuran satu card rata-rata
        el.scrollBy({ left: el.clientWidth > 400 ? 320 : 280, behavior: 'smooth' });
      }
    }, intervalTime);
  }
  
  // Mengaktifkan auto-scroll pada flash sale dan review
  setupAutoScroll('flash-scroll', 3500);
  setupAutoScroll('review-scroll', 4500);
</script>

