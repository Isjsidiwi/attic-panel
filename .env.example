# Turso Database (dari Vercel Dashboard → Storage → Connect Project)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT (ganti dengan string random panjang)
JWT_SECRET=ganti-dengan-random-string-yang-panjang

# Default admin saat pertama kali deploy
# Setelah deploy, ganti via Settings page
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Panel settings
PANEL_NAME=ATTIC PANEL

# Secret salt APK (dari hasil reverse engineering)
SALT=Vm8Lk7Uj2JmsjCPVPVjrLa7zgfx3uz9E
